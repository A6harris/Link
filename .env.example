# Analytics (optional)
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Error Tracking (optional)
EXPO_PUBLIC_SENTRY_DSN=

# Feature Requests (optional)
# Google Apps Script Web App URL that records ideas to a Sheet and emails the team.
# See docs/feature-request-apps-script.md to deploy. Leave blank to disable the form.
EXPO_PUBLIC_FEATURE_REQUEST_URL=
