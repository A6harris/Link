{
  "expo": {
    "name": "Link",
    "slug": "Link",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.evanaden.linkapp",
      "buildNumber": "2",
      "minimumOsVersion": "16.0",
      "supportsTablet": false,
      "infoPlist": {
        "NSContactsUsageDescription": "Link uses your contacts to help you stay in touch with the people you care about.",
        "NSCameraUsageDescription": "Link uses the camera to set profile photos for your contacts.",
        "NSPhotoLibraryUsageDescription": "Link accesses your photo library to set profile photos for your contacts.",
        "NSPhotoLibraryAddUsageDescription": "Link saves photos to your library when you update a contact's profile picture.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": [
              "C617.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": [
              "C617.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-contacts",
        {
          "contactsPermission": "Link uses your contacts to help you stay in touch with the people you care about."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Link accesses your photo library to set profile photos for your contacts.",
          "cameraPermission": "Link uses the camera to set profile photos for your contacts."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#9B59B6"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f5c533f2-2ca5-4e38-a288-7a04bbe25692"
      }
    }
  }
}
