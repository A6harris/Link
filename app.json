{
  "expo": {
    "name": "Link",
    "slug": "Link",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.evanaden.linkapp",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSContactsUsageDescription": "Link uses your contacts to help you stay in touch with the people you care about.",
        "NSCameraUsageDescription": "Link uses the camera to set profile photos for your contacts.",
        "NSPhotoLibraryUsageDescription": "Link accesses your photo library to set profile photos for your contacts.",
        "NSPhotoLibraryAddUsageDescription": "Link saves photos to your library when you update a contact's profile picture.",
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
